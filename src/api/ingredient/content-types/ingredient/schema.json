{
  "kind": "collectionType",
  "collectionName": "ingredients",
  "info": {
    "singularName": "ingredient",
    "pluralName": "ingredients",
    "displayName": "ingredients"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "stock": {
      "type": "integer"
    },
    "unit": {
      "type": "enumeration",
      "enum": [
        "grams",
        "ml",
        "pcs",
        "kg"
      ]
    },
    "threshold": {
      "type": "integer"
    },
    "isAvailable": {
      "type": "boolean"
    },
    "recipes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::recipe.recipe",
      "mappedBy": "ingredient"
    }
  }
}
