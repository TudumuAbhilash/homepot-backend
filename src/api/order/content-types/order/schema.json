{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "customerName": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "totalAmount": {
      "type": "decimal"
    },
    "orderStatus": {
      "type": "enumeration",
      "default": "Pending",
      "enum": [
        "Pending",
        "Preparing",
        "Ready",
        "Out for Delivery",
        "Delivered",
        "Cancelled"
      ]
    },
    "items": {
      "type": "json"
    }
  }
}
